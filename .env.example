# Токен бота-менеджера франшиз
BOT_TOKEN=

# Твой Telegram ID (главный администратор)
ADMIN_ID=

# Абсолютный путь к папке feAutoSender (один общий экземпляр кода)
FE_AUTO_SENDER_PATH=/path/to/feAutoSender

# Путь к БД менеджера
DATABASE_PATH=data/manager.db

# Комиссия на вывод (0.07 = 7%)
WITHDRAWAL_COMMISSION=0.07

# Минимальная сумма подписки (нижний порог для всех франшиз)
MIN_SUBSCRIPTION_PRICE=3.0
